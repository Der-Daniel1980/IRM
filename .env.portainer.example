# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  IRM — Portainer Environment Variables                                   ║
# ║                                                                          ║
# ║  Diese Werte in Portainer unter "Environment variables" eintragen.       ║
# ║  Alle Passwörter/Secrets MÜSSEN geändert werden!                        ║
# ║                                                                          ║
# ║  Secrets generieren:                                                     ║
# ║    openssl rand -base64 32                                               ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_IP=192.168.0.21

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=irm
POSTGRES_PASSWORD=HIER_SICHERES_PASSWORT_SETZEN
POSTGRES_DB=irm

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=HIER_SICHERES_PASSWORT_SETZEN

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=HIER_SICHERES_PASSWORT_SETZEN
KEYCLOAK_REALM=irm
KEYCLOAK_CLIENT_ID=irm-backend
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_CLIENT_ID_FRONTEND=irm-frontend

# ── Meilisearch ───────────────────────────────────────────────────────────────
MEILISEARCH_API_KEY=HIER_SICHEREN_API_KEY_SETZEN

# ── Auth / Security ──────────────────────────────────────────────────────────
JWT_SECRET=HIER_RANDOM_STRING_MIN_32_ZEICHEN
NEXTAUTH_SECRET=HIER_ANDERER_RANDOM_STRING_MIN_32_ZEICHEN

# ── Scheduling ────────────────────────────────────────────────────────────────
WORK_DAY_START=07:00
WORK_DAY_END=17:00
BUFFER_BETWEEN_ORDERS_MIN=15
