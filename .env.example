# ╔══════════════════════════════════════════════════════════════════════╗
# ║  IRM — Umgebungsvariablen                                            ║
# ║  Immobilien- & Ressourcenmanagement                                  ║
# ║                                                                      ║
# ║  Verwendung:                                                         ║
# ║    cp .env.example .env                                              ║
# ║    Alle ⚠️  ÄNDERN!-Werte anpassen, dann 'make up' ausführen.        ║
# ║                                                                      ║
# ║  Legende:                                                            ║
# ║    # PFLICHT   → Muss gesetzt sein, sonst startet die App nicht      ║
# ║    # ⚠️ ÄNDERN! → Unsicherer Standardwert, MUSS geändert werden       ║
# ╚══════════════════════════════════════════════════════════════════════╝


# ══════════════════════════════════════════════════════════
# 🗄️  DATENBANK (PostgreSQL 16 + PostGIS)
# ══════════════════════════════════════════════════════════

# Hostname des PostgreSQL-Servers (Docker-Service-Name oder IP)
# PFLICHT
POSTGRES_HOST=localhost

# Port des PostgreSQL-Servers
# PFLICHT
POSTGRES_PORT=5432

# PostgreSQL-Datenbankbenutzer
# PFLICHT
POSTGRES_USER=irm

# PostgreSQL-Passwort — NIEMALS in der Versionsverwaltung belassen!
# PFLICHT | ⚠️ ÄNDERN!
POSTGRES_PASSWORD=irm_secret_change_me

# Name der Datenbank (Dev: irm_dev, Prod: irm)
# PFLICHT
POSTGRES_DB=irm_dev

# Vollständige Prisma-Connection-URL — wird aus den obigen Werten zusammengesetzt
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
# PFLICHT | ⚠️ ÄNDERN! (muss mit POSTGRES_* übereinstimmen)
DATABASE_URL=postgresql://irm:irm_secret_change_me@localhost:5432/irm_dev

# Maximale Anzahl gleichzeitiger DB-Verbindungen im Connection-Pool
DATABASE_POOL_SIZE=10

# Datenbankschema (Standard: public)
DATABASE_SCHEMA=public


# ══════════════════════════════════════════════════════════
# 📡 REDIS (BullMQ-Queue + Pub/Sub)
# ══════════════════════════════════════════════════════════

# Hostname des Redis-Servers (Docker-Service-Name oder IP)
# PFLICHT
REDIS_HOST=localhost

# Port des Redis-Servers
# PFLICHT
REDIS_PORT=6379

# Redis-Passwort (leer = kein Passwort, in Produktion SETZEN!)
# ⚠️ ÄNDERN! (in Produktion)
REDIS_PASSWORD=

# Redis-Datenbank-Index (0–15)
REDIS_DB=0

# Maximale Wiederholungsversuche für fehlgeschlagene Queue-Jobs
BULL_MAX_RETRIES=3

# Verzögerung zwischen Wiederholungsversuchen in Millisekunden
BULL_RETRY_DELAY_MS=5000


# ══════════════════════════════════════════════════════════
# 🔑 KEYCLOAK (Authentifizierung & Autorisierung)
# ══════════════════════════════════════════════════════════

# Basis-URL des Keycloak-Servers (ohne abschließenden Slash)
# PFLICHT
KEYCLOAK_URL=http://localhost:8080

# Name des Keycloak-Realms
# PFLICHT
KEYCLOAK_REALM=irm

# Client-ID für das Backend (Confidential Client)
# PFLICHT
KEYCLOAK_CLIENT_ID=irm-backend

# Client-Secret des Backend-Clients — in der Keycloak-Admin-UI einsehen
# PFLICHT | ⚠️ ÄNDERN!
KEYCLOAK_CLIENT_SECRET=change_me

# Benutzername des Keycloak-Administrators
# PFLICHT | ⚠️ ÄNDERN!
KEYCLOAK_ADMIN_USER=admin

# Passwort des Keycloak-Administrators
# PFLICHT | ⚠️ ÄNDERN!
KEYCLOAK_ADMIN_PASSWORD=admin_change_me

# Client-ID für das Frontend (Public Client, kein Secret nötig)
KEYCLOAK_FRONTEND_CLIENT_ID=irm-frontend

# JWKS-URI für Token-Validierung (wird automatisch aus KEYCLOAK_URL + KEYCLOAK_REALM gebildet)
# Nur setzen wenn von der Standardform abgewichen wird
# KEYCLOAK_JWKS_URI=http://localhost:8080/realms/irm/protocol/openid-connect/certs


# ══════════════════════════════════════════════════════════
# 🔍 MEILISEARCH (Volltextsuche)
# ══════════════════════════════════════════════════════════

# URL des Meilisearch-Servers
# PFLICHT
MEILISEARCH_HOST=http://localhost:7700

# Master-API-Key für Meilisearch (zum Erstellen von Index-Schlüsseln)
# PFLICHT | ⚠️ ÄNDERN!
MEILISEARCH_API_KEY=change_me

# Welche Felder in der Suche indiziert werden (kommasepariert)
MEILISEARCH_SEARCHABLE_ATTRIBUTES=name,description,address,customerNumber


# ══════════════════════════════════════════════════════════
# 🖥️  APP (Backend NestJS)
# ══════════════════════════════════════════════════════════

# Port auf dem das Backend läuft
# PFLICHT
APP_PORT=3001

# Umgebung: development | staging | production
# PFLICHT
APP_ENV=development

# Basis-URL des Backends (für interne Links, PDF-Generierung etc.)
APP_URL=http://localhost:3001

# CORS: Erlaubte Origins (kommasepariert, * = alle erlauben — nur für Dev!)
# ⚠️ ÄNDERN! (in Produktion konkrete URL setzen)
CORS_ORIGINS=http://localhost:3002

# Log-Level: error | warn | log | debug | verbose
LOG_LEVEL=log

# Swagger/OpenAPI aktivieren (true in Dev, false in Prod empfohlen)
SWAGGER_ENABLED=true


# ══════════════════════════════════════════════════════════
# 🖥️  FRONTEND (Next.js)
# ══════════════════════════════════════════════════════════

# Öffentliche Backend-API-URL (wird im Browser aufgerufen)
# PFLICHT
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Öffentliche Keycloak-URL (wird im Browser aufgerufen)
# PFLICHT
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080

# Keycloak-Realm für das Frontend
# PFLICHT
NEXT_PUBLIC_KEYCLOAK_REALM=irm

# Keycloak-Client-ID für das Frontend (Public Client)
# PFLICHT
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=irm-frontend

# Backend-URL für Server-Side-Requests (intern, nicht vom Browser)
BACKEND_URL=http://localhost:3001

# Aktiviert React Query Devtools (nur in Dev sinnvoll)
NEXT_PUBLIC_REACT_QUERY_DEVTOOLS=true


# ══════════════════════════════════════════════════════════
# 🔐 AUTH & SICHERHEIT
# ══════════════════════════════════════════════════════════

# JWT-Secret für Token-Signierung (mindestens 32 Zeichen!)
# Generieren: openssl rand -base64 48
# PFLICHT | ⚠️ ÄNDERN!
JWT_SECRET=change_me_to_random_string_min_32_chars

# JWT-Token-Gültigkeitsdauer (z.B. 1h, 8h, 1d)
JWT_EXPIRES_IN=8h

# Refresh-Token-Gültigkeitsdauer
JWT_REFRESH_EXPIRES_IN=7d

# Session-Secret für Next-Auth (mindestens 32 Zeichen!)
# Generieren: openssl rand -base64 48
# PFLICHT | ⚠️ ÄNDERN!
NEXTAUTH_SECRET=change_me_to_another_random_string

# NextAuth-URL (Basis-URL des Frontends)
NEXTAUTH_URL=http://localhost:3002

# Passwort-Hashing-Runden (10–14 empfohlen, höher = sicherer aber langsamer)
BCRYPT_ROUNDS=12


# ══════════════════════════════════════════════════════════
# 📅 SCHEDULING-ENGINE
# ══════════════════════════════════════════════════════════

# Beginn des Arbeitstages (HH:MM, 24h-Format)
# PFLICHT
WORK_DAY_START=07:00

# Ende des Arbeitstages (HH:MM, 24h-Format)
# PFLICHT
WORK_DAY_END=17:00

# Pufferzeit zwischen zwei Aufträgen in Minuten
# PFLICHT
BUFFER_BETWEEN_ORDERS_MIN=15

# Maximale Fahrzeit zum Einsatzort in Minuten (Aufträge darüber werden nicht vorgeschlagen)
MAX_TRAVEL_TIME_MIN=60

# Gewichtung der Entfernung beim Scoring (0.0–1.0, Rest geht auf Fähigkeits-Level)
SCHEDULING_DISTANCE_WEIGHT=0.4

# Gewichtung des Fähigkeits-Levels beim Scoring (0.0–1.0)
SCHEDULING_SKILL_WEIGHT=0.6

# Anzahl der Scheduling-Vorschläge die pro Auftrag zurückgegeben werden
SCHEDULING_MAX_SUGGESTIONS=5

# Durchschnittliche Fahrgeschwindigkeit in km/h (für Zeitberechnung ohne Echtzeit-Traffic)
AVG_TRAVEL_SPEED_KMH=40

# Anzahl paralleler Scheduling-Worker in der BullMQ-Queue
SCHEDULING_QUEUE_CONCURRENCY=3


# ══════════════════════════════════════════════════════════
# 🏢 FIRMA (für Laufzettel, PDFs, E-Mails)
# ══════════════════════════════════════════════════════════

# Firmenname (erscheint auf Laufzetteln und PDFs)
COMPANY_NAME=Meine Immobilienverwaltung GmbH

# Firmenadresse Zeile 1
COMPANY_ADDRESS_LINE1=Musterstraße 1

# Firmenadresse Zeile 2 (PLZ Ort)
COMPANY_ADDRESS_LINE2=12345 Musterstadt

# Firmen-Telefonnummer
COMPANY_PHONE=+49 123 456789

# Firmen-E-Mail
COMPANY_EMAIL=info@beispiel.de

# Firmen-Website (optional, für Footer auf PDFs)
COMPANY_WEBSITE=https://www.beispiel.de

# Pfad zum Firmenlogo (relativ zu packages/backend/public/)
COMPANY_LOGO_PATH=logo.png

# Steuernummer / USt-IdNr. (für Dokumente)
COMPANY_TAX_ID=DE123456789


# ══════════════════════════════════════════════════════════
# 📄 PDF-GENERIERUNG (Puppeteer / Laufzettel)
# ══════════════════════════════════════════════════════════

# Timeout für PDF-Generierung in Millisekunden
PDF_GENERATION_TIMEOUT_MS=30000

# Papierformat für Laufzettel (A4 | Letter)
PDF_PAPER_FORMAT=A4

# Verzeichnis zum Zwischenspeichern generierter PDFs
PDF_OUTPUT_DIR=./tmp/pdf

# Puppeteer: Chromium-Pfad (leer = automatisch, setzen wenn eigene Installation)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser


# ══════════════════════════════════════════════════════════
# 📧 E-MAIL (optional, für Benachrichtigungen)
# ══════════════════════════════════════════════════════════

# SMTP-Hostname
SMTP_HOST=smtp.beispiel.de

# SMTP-Port (587 = STARTTLS, 465 = SSL, 25 = unverschlüsselt)
SMTP_PORT=587

# SMTP-Benutzername
SMTP_USER=irm@beispiel.de

# SMTP-Passwort
# ⚠️ ÄNDERN!
SMTP_PASSWORD=change_me

# TLS für SMTP erzwingen (true | false)
SMTP_SECURE=true

# Absender-Adresse für System-E-Mails
SMTP_FROM=IRM System <irm@beispiel.de>

# E-Mail-Benachrichtigungen aktivieren (true | false)
EMAIL_NOTIFICATIONS_ENABLED=false


# ══════════════════════════════════════════════════════════
# === PRODUCTION ONLY ===
# Folgende Variablen sind NUR in der Produktionsumgebung relevant.
# In der Entwicklung können sie leer bleiben.
# ══════════════════════════════════════════════════════════

# Öffentliche Domain der Anwendung (ohne Protokoll)
# Beispiel: irm.meinfirma.de
# ⚠️ ÄNDERN!
DOMAIN=irm.example.com

# E-Mail für Let's Encrypt Zertifikate (Ablauf-Benachrichtigungen)
# ⚠️ ÄNDERN!
LETSENCRYPT_EMAIL=admin@irm.example.com

# Vollständige öffentliche URL des Frontends (mit Protokoll)
# ⚠️ ÄNDERN!
PUBLIC_URL=https://irm.example.com

# Vollständige öffentliche URL der API
# ⚠️ ÄNDERN!
PUBLIC_API_URL=https://irm.example.com/api/v1

# Pfad zum SSL-Zertifikat (für Nginx/Reverse-Proxy)
# ⚠️ ÄNDERN!
SSL_CERT_PATH=/etc/letsencrypt/live/irm.example.com/fullchain.pem

# Pfad zum SSL-Zertifikat-Schlüssel
# ⚠️ ÄNDERN!
SSL_KEY_PATH=/etc/letsencrypt/live/irm.example.com/privkey.pem

# Keycloak-URL in Produktion (hinter Reverse-Proxy)
# ⚠️ ÄNDERN!
KEYCLOAK_PROD_URL=https://irm.example.com/auth

# Docker-Registry für Produktions-Images (optional)
# DOCKER_REGISTRY=registry.example.com/irm

# Version/Tag der Docker-Images für Produktion
DOCKER_IMAGE_TAG=latest

# Datenbankname in Produktion (empfohlen: irm statt irm_dev)
# POSTGRES_DB=irm

# PostgreSQL-Datenbankhost in Produktion (z.B. managed DB-Service)
# POSTGRES_HOST=db.example.com

# Anzahl der Backend-Instanzen (für Horizontal Scaling)
BACKEND_REPLICAS=1

# Rate-Limiting: Maximale Anfragen pro Minute pro IP
RATE_LIMIT_RPM=100

# Backup-Aufbewahrungszeit in Tagen
BACKUP_RETENTION_DAYS=30

# S3-kompatibler Storage für Backups (optional)
# BACKUP_S3_BUCKET=irm-backups
# BACKUP_S3_ENDPOINT=https://s3.example.com
# BACKUP_S3_ACCESS_KEY=change_me
# BACKUP_S3_SECRET_KEY=change_me
